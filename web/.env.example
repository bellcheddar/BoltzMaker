# Copy to web/.env and fill in. web/.env is gitignored -- never commit real server details.

# --- Deploy target (used by web/deploy/deploy.sh) ---
# SSH destination for rsync, e.g. root@boltzmaker.mdeller.com or an ~/.ssh/config alias.
DROPLET_SSH=root@mdeller.com
# Absolute path on the droplet where the code lives (provision.sh creates this).
DROPLET_PATH=/opt/boltzmaker
# Optional explicit SSH key (else your default agent/key is used).
# SSH_KEY=~/.ssh/id_ed25519

# --- Web serving (used by nginx + gunicorn config) ---
# Public hostname certbot issues a cert for and nginx answers on.
SERVER_NAME=boltzmaker.mdeller.com
# Address gunicorn binds to (nginx reverse-proxies TLS -> here). 8003: 8000 is
# AlphaFraud's, 8002 is chatPDB's -- pick a free port if either of those changes.
BIND_ADDR=127.0.0.1:8003

# --- Optional cert email override ---
# CERTBOT_EMAIL=marc@marcdeller.com
